{
  "$defs": {
    "Claim": {
      "additionalProperties": false,
      "description": "A source-grounded claim with fidelity metadata.",
      "properties": {
        "value": {
          "anyOf": [
            {},
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "fidelity": {
          "$ref": "#/$defs/FidelityState",
          "default": "missing"
        },
        "evidence_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "rationale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rationale"
        },
        "candidates": {
          "items": {
            "$ref": "#/$defs/ConflictCandidate"
          },
          "title": "Candidates",
          "type": "array"
        },
        "conflict_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Conflict Reason"
        },
        "impact": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Impact"
        }
      },
      "title": "Claim",
      "type": "object"
    },
    "ConflictCandidate": {
      "additionalProperties": false,
      "description": "One candidate value preserved for a conflicting source claim.",
      "properties": {
        "value": {
          "title": "Value"
        },
        "evidence_refs": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "preferred": {
          "default": false,
          "title": "Preferred",
          "type": "boolean"
        },
        "rationale": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rationale"
        }
      },
      "required": [
        "value"
      ],
      "title": "ConflictCandidate",
      "type": "object"
    },
    "FidelityState": {
      "description": "Source-fidelity state for an extracted design claim.",
      "enum": [
        "explicit",
        "inferred",
        "missing",
        "conflict"
      ],
      "title": "FidelityState",
      "type": "string"
    },
    "WorkflowEdge": {
      "additionalProperties": false,
      "description": "Basic typed workflow graph edge.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        },
        "condition": {
          "$ref": "#/$defs/Claim"
        }
      },
      "required": [
        "id",
        "source",
        "target"
      ],
      "title": "WorkflowEdge",
      "type": "object"
    },
    "WorkflowGraph": {
      "additionalProperties": false,
      "description": "Generic nodes + edges workflow graph.",
      "properties": {
        "nodes": {
          "items": {
            "$ref": "#/$defs/WorkflowNode"
          },
          "title": "Nodes",
          "type": "array"
        },
        "edges": {
          "items": {
            "$ref": "#/$defs/WorkflowEdge"
          },
          "title": "Edges",
          "type": "array"
        }
      },
      "title": "WorkflowGraph",
      "type": "object"
    },
    "WorkflowNode": {
      "additionalProperties": false,
      "description": "Basic typed workflow graph node.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "type": {
          "default": "unknown",
          "title": "Type",
          "type": "string"
        },
        "description": {
          "$ref": "#/$defs/Claim"
        }
      },
      "required": [
        "id",
        "label"
      ],
      "title": "WorkflowNode",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Graph representation of the extracted agent workflow.",
  "properties": {
    "schema_version": {
      "default": "0.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "graph": {
      "$ref": "#/$defs/WorkflowGraph"
    },
    "evidence_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "title": "Evidence Refs",
      "type": "array"
    }
  },
  "title": "WorkflowSpec",
  "type": "object"
}
